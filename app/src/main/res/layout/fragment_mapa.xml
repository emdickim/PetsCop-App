<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.MapaFragment">

    <!-- Header -->
    <TextView
        android:id="@+id/tvMapaTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="Veterinarios Cercanos"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMapaSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Encuentra la clínica más cercana a ti"
        android:textColor="@color/muted_foreground"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/tvMapaTitle"
        app:layout_constraintTop_toBottomOf="@id/tvMapaTitle" />

    <!-- Buscador y Filtro -->
    <LinearLayout
        android:id="@+id/layoutSearchMapa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvMapaSubtitle">

        <EditText
            android:id="@+id/etBuscarMapa"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_rounded"
            android:backgroundTint="@color/card"
            android:drawableStart="@android:drawable/ic_menu_mylocation"
            android:drawablePadding="12dp"
            android:hint="Buscar por ubicación..."
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/muted_foreground"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/btnFiltroMapa"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_icon_rounded"
            android:backgroundTint="@color/card"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Contenedor del Mapa (OSM) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMapa"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        app:cardBackgroundColor="@color/card"
        app:cardCornerRadius="24dp"
        app:layout_constraintBottom_toTopOf="@id/tvInfoResultados"
        app:layout_constraintTop_toBottomOf="@id/layoutSearchMapa"
        app:strokeWidth="0dp">

        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvInfoResultados"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="24dp"
        android:text="Se encontraron 3 clínicas veterinarias"
        android:textColor="@color/muted_foreground"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>