<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_margin="8dp"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical">

    <!-- Imagen -->
    <ImageView
        android:id="@+id/ivFotoCarrito"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:background="@color/muted"
        android:contentDescription="Producto" />

    <!-- Info del producto -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp">

        <TextView
            android:id="@+id/tvNombreCarrito"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Producto"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/foreground" />

        <TextView
            android:id="@+id/tvPrecioCarrito"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="€0.00"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:textColor="@color/primary"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Controles de cantidad -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMenosCarrito"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="-"
            android:textSize="14sp"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <EditText
            android:id="@+id/etCantidadCarrito"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:text="1"
            android:textSize="12sp"
            android:gravity="center"
            android:inputType="number"
            android:editable="false"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_edit_text" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMasCarrito"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="+"
            android:textSize="14sp"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminarCarrito"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textSize="14sp"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginLeft="8dp"
            app:backgroundTint="@color/destructive"
            style="@style/Widget.MaterialComponents.Button"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </LinearLayout>

</LinearLayout>
