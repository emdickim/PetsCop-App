<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.MarketplaceFragment">

    <TextView
        android:id="@+id/tvMarketTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="Marketplace"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMarketSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Productos veterinarios de confianza"
        android:textColor="@color/muted_foreground"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/tvMarketTitle"
        app:layout_constraintTop_toBottomOf="@id/tvMarketTitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCart"
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="20dp"
        app:backgroundTint="@color/primary"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_menu_agenda"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toBottomOf="@id/tvMarketSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvMarketTitle" />

    <!-- Barra de búsqueda y controles -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvMarketSubtitle">

        <EditText
            android:id="@+id/etBuscarProducto"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_rounded"
            android:backgroundTint="@color/card"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:hint="Buscar productos..."
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/muted_foreground"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/btnFilter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_rounded"
            android:backgroundTint="@color/card"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_rounded"
            android:backgroundTint="@color/card"
            android:orientation="horizontal">

            <ImageButton
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_dialog_dialer"
                app:tint="@color/white" />

            <ImageButton
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_alphabetically"
                app:tint="@color/muted_foreground" />
        </LinearLayout>
    </LinearLayout>

    <!-- Chips de Categorías -->
    <HorizontalScrollView
        android:id="@+id/scrollChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/layoutControls">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCategorias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTodos"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Todos"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/primary" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alimento"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/card" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vacunas"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/card" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medicina"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/card" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMarket"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scrollChips"
        tools:listitem="@layout/item_producto" />

</androidx.constraintlayout.widget.ConstraintLayout>