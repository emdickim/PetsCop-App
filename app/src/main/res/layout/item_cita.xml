<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_icon_rounded"
    android:backgroundTint="@color/card"
    android:padding="16dp">

    <View
        android:id="@+id/viewIndicador"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHoraCita"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="10:30"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/viewIndicador"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMotivoCita"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Revisión Vacunas"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvHoraCita"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvNombreOtro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Clínica Veterinaria Central"
        android:textColor="@color/muted_foreground"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/tvMotivoCita"
        app:layout_constraintStart_toStartOf="@id/tvMotivoCita"
        app:layout_constraintTop_toBottomOf="@id/tvMotivoCita" />

</androidx.constraintlayout.widget.ConstraintLayout>