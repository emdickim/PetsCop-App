<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/card"
    app:cardCornerRadius="20dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Contenedor Imagen -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#232931">

            <ImageView
                android:id="@+id/ivProducto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="30dp"
                android:src="@android:drawable/ic_menu_gallery" />

            <TextView
                android:id="@+id/tvCategoriaTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/bg_icon_rounded"
                android:backgroundTint="#2D343C"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Alimento"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvNombreProd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Alimento Premium para Perros"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDescripcionProd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Royal Canin Adult 15kg"
            android:textColor="@color/muted_foreground"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvClinicaVendedora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Vendido por: Clínica San José"
            android:textColor="@color/muted_foreground"
            android:textSize="13sp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPrecio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="€45.99"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stock: 15 unidades"
                    android:textColor="@color/muted_foreground"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAgregar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Agregar"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconSize="16dp" />
        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>