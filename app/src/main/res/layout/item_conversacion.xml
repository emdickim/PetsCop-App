<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Avatar con iniciales -->
        <TextView
            android:id="@+id/tv_iniciales"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_avatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Punto verde online -->
        <View
            android:id="@+id/view_online"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_online_dot"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/tv_iniciales"
            app:layout_constraintBottom_toBottomOf="@id/tv_iniciales" />

        <!-- Nombre -->
        <TextView
            android:id="@+id/tv_nombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            app:layout_constraintStart_toEndOf="@id/tv_iniciales"
            app:layout_constraintEnd_toStartOf="@id/tv_hora"
            app:layout_constraintTop_toTopOf="@id/tv_iniciales" />

        <!-- Hora -->
        <TextView
            android:id="@+id/tv_hora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_nombre" />

        <!-- Clínica -->
        <TextView
            android:id="@+id/tv_clinica"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toEndOf="@id/tv_iniciales"
            app:layout_constraintEnd_toStartOf="@id/tv_badge"
            app:layout_constraintTop_toBottomOf="@id/tv_nombre" />

        <!-- Badge de mensajes -->
        <TextView
            android:id="@+id/tv_badge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:gravity="center"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_badge"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_hora" />

        <!-- Último mensaje -->
        <TextView
            android:id="@+id/tv_ultimo_mensaje"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/tv_iniciales"
            app:layout_constraintEnd_toStartOf="@id/tv_badge"
            app:layout_constraintTop_toBottomOf="@id/tv_clinica" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>