<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header con Avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="32dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile"
                android:layout_marginBottom="16dp"
                app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full" />

            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mi Perfil"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvClinica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clínica VetPro"
                android:textSize="14sp"
                android:textColor="@color/muted_foreground"
                android:gravity="center"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card de Información Personal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Información Personal"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NOMBRE COMPLETO"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/muted_foreground"
                        android:layout_marginBottom="6dp" />
                    <EditText
                        android:id="@+id/etNombreCompleto"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/input_background"
                        android:hint="Tu nombre"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nº COLEGIADO"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/muted_foreground"
                        android:layout_marginBottom="6dp" />
                    <EditText
                        android:id="@+id/etNumeroColegiado"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/input_background"
                        android:hint="COVB-4892"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TELÉFONO"
                        android:textSize="11sp"
                        android:textColor="@color/muted_foreground"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/input_background"
                        android:inputType="phone"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AÑOS EXPERIENCIA"
                        android:textSize="11sp"
                        android:textColor="@color/muted_foreground"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etAnosExperiencia"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/input_background"
                        android:inputType="number"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESPECIALIDAD"
                android:textSize="11sp"
                android:textColor="@color/muted_foreground"
                android:layout_marginBottom="6dp"/>
            <Spinner
                android:id="@+id/spinnerEspecialidad"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_background"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarPerfil"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Guardar Cambios"
                android:layout_marginTop="8dp"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- Card de Seguridad -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seguridad"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTRASEÑA ACTUAL"
                android:textSize="11sp"
                android:textColor="@color/muted_foreground"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etPasswordActual"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_background"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NUEVA CONTRASEÑA"
                android:textSize="11sp"
                android:textColor="@color/muted_foreground"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etPasswordNueva"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_background"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRMAR CONTRASEÑA"
                android:textSize="11sp"
                android:textColor="@color/muted_foreground"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etPasswordConfirmar"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_background"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCambiarPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Actualizar Seguridad"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
